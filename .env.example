# Database configuration for Docker Compose
DB_USER=basebot
DB_PASSWORD=root
DB_NAME=mydb

# Database URL for Prisma (use 'db' as host for Docker, '127.0.0.1' for local)
DATABASE_URL=mysql://basebot:root@db:3306/mydb

# Telegram Bot Token (get from @BotFather)
BOT_TOKEN=

# JWT Secret (change in production!)
JWT_SECRET=secret@secret

# Initial admin credentials
INITUSERNAME=admin
INITPASSWORD=admin

# Agent workspace - root directory where projects will be created
AGENT_WORKSPACE=/tmp/agent-workspace

# Telegram channels to join (comma-separated, leave empty to disable)
JOINCHANNELS=

# Proxy for Telegram API (optional)
PROXY_TELEGRAM_API=